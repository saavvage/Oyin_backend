# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=sportmatch_dev

# JWT Configuration
JWT_SECRET=super-secret-jwt-key
JWT_EXPIRATION=7d

# Telegram Gateway verification
# local mock code 123456.
TELEGRAM_GATEWAY_ENABLED=false
TELEGRAM_GATEWAY_TOKEN=
# Optional sender username from Gateway settings
TELEGRAM_GATEWAY_SENDER_USERNAME=Oyin
# Verification code settings
TELEGRAM_GATEWAY_CODE_LENGTH=6
TELEGRAM_GATEWAY_CODE_TTL=300
# If true and Telegram Gateway request fails, backend falls back to mock code 123456.
# Recommended true in local/dev, false in production.
AUTH_ALLOW_MOCK_FALLBACK=true

# Firebase Cloud Messaging (server push)
# Keep disabled until Firebase Admin credentials are configured.
FCM_ENABLED=false
# Optional: send without real delivery (for validation/log checks)
FCM_DRY_RUN=false
# Prefer path to Firebase service-account JSON file on backend host:
FCM_SERVICE_ACCOUNT_PATH=
# Alternative to path: raw JSON as single line (escaped newlines)
FCM_SERVICE_ACCOUNT_JSON=
# Alternative split credentials:
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
# Timed reminder scheduler
PUSH_REMINDER_SCHEDULER_ENABLED=true
PUSH_REMINDER_CHECK_INTERVAL_SECONDS=60
FCM_REMINDER_TITLE=Oyin reminder
FCM_REMINDER_BODY=Open the app to check matches, chats and dispute updates.

# Email verification (Brevo) — leave empty to use mock codes (123456)
BREVO_API_URL=https://api.brevo.com/v3
BREVO_API_KEY=
# Must be a verified sender email in Brevo
BREVO_EMAIL_SENDER=
BREVO_EMAIL_SENDER_NAME=Oyin

# ML / AI service
ML_SERVICE_URL=http://localhost:8000
# Example remote dev tunnel:
# ML_SERVICE_URL=https://your-ml-tunnel.trycloudflare.com
GEMINI_API_KEY=
USE_LOCAL_MODEL=false
MODEL_FALLBACK_ENABLED=true
# Path inside oyin-ml container
LOCAL_MODEL_PATH=./models
CHROMA_PERSIST_DIRECTORY=./chroma_db

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://10.0.2.2:3000,http://localhost:8080

# File Upload (for future S3 integration)
UPLOAD_MAX_SIZE=10485760
UPLOAD_AVATAR_DIR=uploads/avatars
# Optional public base url for generated media links
# Example: https://api.example.com
PUBLIC_BASE_URL=
