# SMS Service Configuration (Mock for now)
SMS_PROVIDER=mock
SMS_API_KEY=mock-key

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# File Upload (for future S3 integration)
UPLOAD_MAX_SIZE=10485760
